APP_ENV=development
APP_PORT=8080
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

POSTGRES_DB=finance_app
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=change_this_database_password
POSTGRES_PORT=5432

# Use pelo menos 32 caracteres e nunca reutilize o valor de desenvolvimento em produção.
JWT_SECRET=change_this_to_a_long_random_secret_with_32_chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

AI_PROVIDER=local
AI_API_KEY=
